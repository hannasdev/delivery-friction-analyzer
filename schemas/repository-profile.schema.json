{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delivery-friction-analyzer.local/schemas/repository-profile.schema.json",
  "title": "RepositoryProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "rules"],
  "properties": {
    "schemaVersion": {
      "const": "repository-profile.v1"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "name"],
      "properties": {
        "owner": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "match", "category", "role"],
        "properties": {
          "id": { "type": "string" },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "exact": { "type": "string" },
              "prefix": { "type": "string" },
              "suffix": { "type": "string" },
              "includes": { "type": "string" },
              "regex": { "type": "string" }
            },
            "minProperties": 1
          },
          "category": {
            "enum": ["code", "tests", "docs", "config", "generated", "infrastructure", "unknown"]
          },
          "role": {
            "enum": [
              "core_product_code",
              "product_ui",
              "tests",
              "generated_docs",
              "release_notes",
              "planning_docs",
              "marketing_site",
              "config",
              "infrastructure",
              "fixtures",
              "generated_or_vendored",
              "unknown"
            ]
          },
          "functionalSurface": { "type": "string" },
          "generated": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "prClasses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "class", "match"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "class": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "titleIncludes": { "type": "string", "minLength": 1 },
              "titleRegex": { "type": "string", "minLength": 1 }
            },
            "minProperties": 1
          },
          "notes": { "type": "string" }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primaryMergeMethod": {
          "enum": ["merge_commit", "squash_merge", "rebase_merge", "mixed", "unknown"]
        },
        "releaseStrategy": {
          "enum": ["release_prs", "direct_tags", "release_branches", "mixed", "unknown"]
        },
        "branchStrategy": {
          "enum": ["trunk_based", "main_plus_release_branches", "long_lived_development_branches", "mixed", "unknown"]
        }
      },
      "minProperties": 1
    },
    "contributors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceType": {
          "enum": ["all_contributors"]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "\\\\" },
              { "pattern": "(^|/)\\.\\.(/|$)" }
            ]
          }
        }
      },
      "minProperties": 1
    }
  }
}
